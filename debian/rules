#!/usr/bin/make -f
# See debhelper(7) (uncomment to enable)
# output every command that modifies files on the build system.
#export DH_VERBOSE = 1

%:
	dh $@

override_dh_auto_build:
	md5sum /usr/src/saa716x-0.5/* >/tmp/saa716x-0.5.md5sum
	diff -q /tmp/saa716x-0.5.md5sum /usr/share/doc/saa716x-dkms/saa716x-0.5.md5sum
	rm -f /tmp/saa716x-0.5.md5sum
	dh_auto_build $@
